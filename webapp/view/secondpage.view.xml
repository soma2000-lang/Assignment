<mvc:View controllerName="deloitte.training.sapui5ap.controller.secondpage"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="page" title="{i18n>title}">
        <!-- <Text text="I am on Second Page."/> -->
        <Table id="idProductsTable"
		items="{
			path: 'products>/ProductCollection'
		}">
		<columns>
			<Column
				width="12em">
				<Text text="Product" />
			</Column>
			<Column
				minScreenWidth="Tablet"
				demandPopin="true">
				<Text text="Product Name" />
			</Column>
		</columns>
		<items>
			<ColumnListItem vAlign="Middle">
				<cells>
				<ObjectIdentifier
						title="{products>ProductId}"/>
					<Text
						text="{products>ProductName}" />
				</cells>
			</ColumnListItem>
		</items>
	</Table>
    </Page>
</mvc:View>
