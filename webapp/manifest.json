{
  "_version": "1.49.0",
  "sap.app": {
    "id": "deloitte.training.sapui5ap",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.11.1",
      "toolsId": "209718f5-3c8e-479d-8e4e-3b72c7601036"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.118.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.suite.ui.generic.template": {},
        "sap.ui.comp": {},
        "sap.ui.generic.app": {},
        "sap.ui.table": {},
        "sap.ushell": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "deloitte.training.sapui5ap.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "deloitte.training.sapui5ap.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "Routesapui5app",
          "pattern": ":?query:",
          "target": [
            "Targetsapui5app"
          ]
        },
        {
          "name": "secondpage",
          "pattern": "secondpage",
          "target": "secondpage"
        }
      ],
      "targets": {
        "Targetsapui5app": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "sapui5app",
          "viewName": "sapui5app"
        },
        "secondpage": {
          "viewId": "secondpage",
          "viewName": "secondpage",
          "viewLevel": 2
        }
      }
    },
    "rootView": {
      "viewName": "deloitte.training.sapui5ap.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}
